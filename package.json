{
  "name": "lhnhs-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "bun run --bun astro dev",
    "build:client": "bun run --bun astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.{js,ts,tsx,astro}'",
    "worker": "wrangler dev",
    "dev": "concurrently \"bun run client\" \"bun run worker\"",
    "dryrun:staging": "bun run build:client && wrangler deploy --dry-run --env staging",
    "dryrun:prod": "bun run build:client && wrangler deploy --dry-run --env production",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production",
    "db:generate": "drizzle-kit generate --config=drizzle.local.config.ts",
    "db:migrate:local": "drizzle-kit migrate --config=drizzle.local.config.ts",
    "db:migrate:staging": "drizzle-kit migrate --config=drizzle.staging.config.ts",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.7.0",
    "@astrojs/react": "5.0.7",
    "@cloudinary/react": "^1.14.4",
    "@cloudinary/url-gen": "^1.22.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "astro": "6.4.6",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^1.7.0",
    "hono": "^4.12.27",
    "lucide-react": "^1.22.0",
    "pg": "^8.22.0",
    "prettier": "^3.9.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.105.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.3",
    "daisyui": "^5.6.6",
    "drizzle-kit": "^0.31.10",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
