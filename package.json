{
  "name": "lhnhs-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "bun run --bun astro dev",
    "build:client": "bun run --bun astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.{js,ts,tsx,astro}'",
    "worker": "wrangler dev",
    "dev": "concurrently \"bun run client\" \"bun run worker\"",
    "dryrun:staging": "bun run build:client && wrangler deploy --dry-run --env staging",
    "dryrun:prod": "bun run build:client && wrangler deploy --dry-run --env production",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply lhnhs-project-local-database --local",
    "db:migrate:staging": "wrangler d1 migrations apply lhnhs-project-staging-database --remote --env staging"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.2",
    "astro": "^6.2.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.88.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.1",
    "@types/bun": "^1.3.13",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
